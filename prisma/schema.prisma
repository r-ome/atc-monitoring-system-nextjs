model activity_logs {
  activity_log_id String          @id @default(uuid())
  username        String
  branch_id       String
  branch_name     String
  action          activity_action
  entity_type     String
  entity_id       String
  description     String          @db.Text
  created_at      DateTime        @default(now()) @db.Timestamp(0)
  branch          branches        @relation(fields: [branch_id], references: [branch_id])

  @@index([branch_id])
  @@index([created_at])
  @@index([entity_type])
}
