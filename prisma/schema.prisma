generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model auctions {
  auction_id         String             @id @default(uuid())
  created_at         DateTime           @default(now()) @db.Timestamp(0)
  updated_at         DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at         DateTime?          @db.DateTime(0)
  branch_id          String             @default("bd163cce-98e5-4513-b69e-875bd89c5f5c")
  branch             branches           @relation(fields: [branch_id], references: [branch_id])
  registered_bidders auctions_bidders[]
  manifest_records   manifest_records[]
  counter_check      counter_check[]
}

model auctions_bidders {
  auction_bidder_id    String                 @id @default(uuid())
  auction_id           String
  bidder_id            String
  service_charge       Int                    @default(0)
  already_consumed     Int                    @default(0) @db.TinyInt
  registration_fee     Int                    @default(0)
  balance              Int                    @default(0)
  remarks              String?                @db.Text
  created_at           DateTime               @default(now()) @db.Timestamp(0)
  updated_at           DateTime               @default(now()) @updatedAt @db.DateTime(0)
  deleted_at           DateTime?              @db.DateTime(0)
  auctions             auctions               @relation(fields: [auction_id], references: [auction_id], onDelete: Cascade, map: "fk_auctions_bidders_auctions")
  bidder               bidders                @relation(fields: [bidder_id], references: [bidder_id], onDelete: Cascade, map: "fk_auctions_bidders_bidders")
  auctions_inventories auctions_inventories[]
  receipt_records      receipt_records[]

  @@index([auction_id], map: "fk_auctions_bidders_auctions")
  @@index([bidder_id], map: "fk_auctions_bidders_bidders")
}

model auctions_inventories {
  auction_inventory_id            String                   @id @default(uuid())
  auction_bidder_id               String
  inventory_id                    String                   @unique
  receipt_id                      String?
  description                     String
  status                          auction_inventory_status @default(UNPAID)
  price                           Int                      @default(0)
  qty                             String
  manifest_number                 String
  is_slash_item                   String?
  split_from_auction_inventory_id String?
  auction_date                    DateTime
  created_at                      DateTime                 @default(now()) @db.Timestamp(0)
  updated_at                      DateTime                 @default(now()) @updatedAt @db.DateTime(0)
  deleted_at                      DateTime?                @db.DateTime(0)
  auction_bidder                  auctions_bidders         @relation(fields: [auction_bidder_id], references: [auction_bidder_id], onDelete: Cascade, map: "fk_auctions_inventories_auctions_bidders")
  // inventory            inventories              @relation(fields: [inventory_id], references: [inventory_id], onDelete: Cascade, map: "fk_auctions_inventories_inventories")
  inventory                       inventories              @relation("InventoryToAuctionInventories", fields: [inventory_id], references: [inventory_id])
  receipt                         receipt_records?         @relation(fields: [receipt_id], references: [receipt_id], onDelete: Cascade, map: "fk_auctions_inventories_receipt")
  histories                       inventory_histories[]

  @@index([auction_bidder_id], map: "fk_auctions_inventories_auctions_bidders")
  @@index([inventory_id], map: "fk_auctions_inventories_inventories")
  @@index([receipt_id], map: "fk_auctions_inventories_receipt")
}

model bidder_requirements {
  requirement_id String    @id @default(uuid())
  bidder_id      String
  name           String
  url            String?
  validity_date  DateTime? @db.DateTime(0)
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  updated_at     DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at     DateTime? @db.DateTime(0)
  bidders        bidders   @relation(fields: [bidder_id], references: [bidder_id], onDelete: Cascade, map: "fk_bidder_requirements_bidders")

  @@index([bidder_id], map: "fk_bidder_requirements_bidders")
}

model bidders {
  bidder_id        String                 @id @default(uuid())
  bidder_number    String
  first_name       String
  middle_name      String?
  last_name        String
  birthdate        DateTime?              @db.DateTime(0)
  contact_number   String?
  registration_fee Int                    @default(0)
  service_charge   Int                    @default(0)
  status           bidder_status
  remarks          String?                @db.Text
  address          String?
  tin_number       String?
  store_name       String?
  branch_id        String
  payment_term     Int                    @default(7)
  created_at       DateTime               @default(now()) @db.Timestamp(0)
  updated_at       DateTime               @default(now()) @updatedAt @db.DateTime(0)
  deleted_at       DateTime?
  auctions_joined  auctions_bidders[]
  requirements     bidder_requirements[]
  ban_histories    bidder_ban_histories[]
  branch           branches               @relation(fields: [branch_id], references: [branch_id])
}

model bidder_ban_histories {
  bidder_ban_history_id String    @id @default(uuid())
  bidder_id             String
  remarks               String    @db.Text
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  updated_at            DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at            DateTime? @db.DateTime(0)
  bidder                bidders   @relation(fields: [bidder_id], references: [bidder_id], onDelete: Cascade, map: "fk_bidder_ban_histories_bidders")

  @@index([bidder_id], map: "fk_bidder_ban_histories_bidders")
}

model branches {
  branch_id       String            @id @default(uuid())
  name            String
  created_at      DateTime          @default(now()) @db.Timestamp(0)
  updated_at      DateTime          @default(now()) @updatedAt @db.DateTime(0)
  deleted_at      DateTime?
  containers      containers[]
  users           users[]
  bidders         bidders[]
  auctions        auctions[]
  expenses        expenses[]
  pettyCashes     petty_cash[]
  activity_logs   activity_logs[]
  employees       employees[]
  payroll_periods payroll_periods[]
}

model containers {
  container_id               String                                 @id @default(uuid())
  supplier_id                String
  branch_id                  String
  barcode                    String                                 @unique
  bill_of_lading_number      String?                                @db.VarChar(255)
  container_number           String?
  arrival_date               DateTime?                              @db.DateTime(0)
  due_date                   DateTime?                              @db.DateTime(0)
  gross_weight               String?                                @db.VarChar(255)
  auction_or_sell            containers_auction_or_sell             @default(SELL)
  status                     DateTime?                              @db.Date
  duties_and_taxes           Decimal                                @default(0) @db.Decimal(10, 2)
  tax_deduction              Json?
  final_report_draft         Json?
  created_at                 DateTime                               @default(now()) @db.Timestamp(0)
  updated_at                 DateTime                               @default(now()) @updatedAt @db.DateTime(0)
  deleted_at                 DateTime?                              @db.DateTime(0)
  branch                     branches                               @relation(fields: [branch_id], references: [branch_id], onDelete: Cascade, map: "fk_containers_branches")
  supplier                   suppliers                              @relation(fields: [supplier_id], references: [supplier_id], onDelete: Cascade, map: "fk_containers_suppliers")
  inventories                inventories[]
  container_files            container_files[]
  item_categories            container_item_categories[]
  item_category_descriptions container_item_category_descriptions[]

  @@index([branch_id], map: "fk_containers_branches")
  @@index([supplier_id], map: "fk_containers_suppliers")
}

model container_files {
  container_file_id String                  @id @default(uuid())
  container_id      String
  document_type     container_document_type
  version           Int
  original_filename String
  s3_bucket         String
  s3_key            String                  @db.Text
  content_type      String
  size_bytes        Int
  uploaded_by       String
  uploaded_at       DateTime                @default(now()) @db.Timestamp(0)
  deleted_by        String?
  deleted_at        DateTime?               @db.DateTime(0)
  created_at        DateTime                @default(now()) @db.Timestamp(0)
  updated_at        DateTime                @default(now()) @updatedAt @db.DateTime(0)
  container         containers              @relation(fields: [container_id], references: [container_id], onDelete: Cascade, map: "fk_container_files_containers")

  @@unique([container_id, document_type, version], map: "container_files_container_document_version_key")
  @@index([container_id, document_type, deleted_at], map: "container_files_container_document_deleted_idx")
  @@index([container_id], map: "fk_container_files_containers")
}

model inventories {
  inventory_id   String             @id @default(uuid())
  container_id   String
  barcode        String
  control        String?
  description    String
  status         inventories_status @default(UNSOLD)
  is_bought_item Int?
  url            String?
  auction_date   DateTime?
  created_at     DateTime           @default(now()) @db.Timestamp(0)
  updated_at     DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at     DateTime?          @db.DateTime(0)
  container      containers         @relation(fields: [container_id], references: [container_id], onDelete: Cascade, map: "fk_inventories_container_id")

  auctions_inventory auctions_inventories? @relation("InventoryToAuctionInventories")
  histories          inventory_histories[]

  @@index([container_id], map: "fk_inventories_container_id")
}

model container_item_categories {
  category_id  String                                 @id @default(uuid())
  container_id String
  name         String                                 @db.VarChar(100)
  created_at   DateTime                               @default(now()) @db.Timestamp(0)
  updated_at   DateTime                               @default(now()) @updatedAt @db.DateTime(0)
  deleted_at   DateTime?                              @db.DateTime(0)
  container    containers                             @relation(fields: [container_id], references: [container_id], onDelete: Cascade, map: "fk_container_item_categories_containers")
  descriptions container_item_category_descriptions[]

  @@index([container_id], map: "fk_container_item_categories_containers")
}

model container_item_category_descriptions {
  category_description_id String                    @id @default(uuid())
  category_id             String
  container_id            String
  description             String                    @db.VarChar(255)
  normalized_description  String                    @db.VarChar(255)
  created_at              DateTime                  @default(now()) @db.Timestamp(0)
  updated_at              DateTime                  @default(now()) @updatedAt @db.DateTime(0)
  category                container_item_categories @relation(fields: [category_id], references: [category_id], onDelete: Cascade, map: "fk_container_item_category_desc_categories")
  container               containers                @relation(fields: [container_id], references: [container_id], onDelete: Cascade, map: "fk_container_item_category_desc_containers")

  @@unique([container_id, normalized_description], map: "container_item_category_desc_container_desc_key")
  @@index([category_id], map: "fk_container_item_category_desc_categories")
  @@index([container_id], map: "fk_container_item_category_desc_containers")
}

model inventory_histories {
  inventory_history_id String                   @id @default(uuid())
  auction_inventory_id String?
  inventory_id         String
  receipt_id           String?
  auction_status       auction_inventory_status
  inventory_status     inventories_status
  remarks              String?                  @db.Text
  created_at           DateTime                 @default(now()) @db.Timestamp(0)
  updated_at           DateTime                 @default(now()) @updatedAt @db.DateTime(0)
  deleted_at           DateTime?                @db.DateTime(0)
  receipt              receipt_records?         @relation(fields: [receipt_id], references: [receipt_id], onDelete: Cascade, map: "fk_inventory_histories_payments")
  inventory            inventories              @relation(fields: [inventory_id], references: [inventory_id], onDelete: Cascade, map: "fk_inventory_histories_inventory")
  auction_inventory    auctions_inventories?    @relation(fields: [auction_inventory_id], references: [auction_inventory_id], map: "fk_inventory_histories_auctions_inventories")

  @@index([auction_inventory_id], map: "fk_inventory_histories_auctions_inventories")
  @@index([inventory_id], map: "fk_inventory_histories_inventory")
  @@index([receipt_id], map: "fk_inventory_histories_receipt_records")
}

model manifest_records {
  manifest_id     String    @id @default(uuid())
  auction_id      String
  barcode         String?
  control         String?
  description     String?
  price           String?
  bidder_number   String?
  qty             String?
  manifest_number String?
  is_slash_item   String?
  remarks         String?   @db.Text
  error_message   String?   @db.Text
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at      DateTime? @db.Timestamp(0)
  auction         auctions  @relation(fields: [auction_id], references: [auction_id], map: "fk_manifest_records_auctions")

  @@index([auction_id], map: "fk_manifest_records_auctions")
}

model receipt_records {
  receipt_id           String                 @id @default(uuid())
  receipt_number       String
  auction_bidder_id    String
  purpose              payments_purpose       @default(REGISTRATION)
  remarks              String?                @db.Text
  created_at           DateTime               @default(now()) @db.Timestamp(0)
  updated_at           DateTime               @default(now()) @updatedAt @db.DateTime(0)
  deleted_at           DateTime?              @db.DateTime(0)
  auction_bidder       auctions_bidders       @relation(fields: [auction_bidder_id], references: [auction_bidder_id], onDelete: Cascade, map: "fk_receipt_records_auctions_bidders")
  auctions_inventories auctions_inventories[]
  payments             payments[]
  inventory_histories  inventory_histories[]

  @@index([auction_bidder_id], map: "fk_receipt_records_auction_bidders")
}

model payments {
  payment_id  String          @id @default(uuid())
  receipt_id  String
  amount_paid Int             @default(0)
  remarks     String?
  created_at  DateTime        @default(now()) @db.Timestamp(0)
  updated_at  DateTime        @default(now()) @updatedAt @db.DateTime(0)
  deleted_at  DateTime?       @db.DateTime(0)
  receipt     receipt_records @relation(fields: [receipt_id], references: [receipt_id], onDelete: Cascade)

  payment_method_id String?
  payment_method    payment_methods? @relation(fields: [payment_method_id], references: [payment_method_id])

  @@index([receipt_id], map: "fk_payments_receipt")
  @@index([payment_method_id], map: "fk_payments_payment_method")
}

model suppliers {
  supplier_id              String       @id @default(uuid())
  name                     String       @unique(map: "name")
  supplier_code            String       @unique(map: "supplier_code")
  japanese_name            String?      @db.VarChar(255)
  commission               String?
  sales_remittance_account String?
  shipper                  String?      @db.VarChar(255)
  email                    String?      @db.VarChar(255)
  contact_number           String?
  created_at               DateTime     @default(now()) @db.Timestamp(0)
  updated_at               DateTime     @default(now()) @updatedAt @db.DateTime(0)
  deleted_at               DateTime?    @db.DateTime(0)
  containers               containers[]
}

model users {
  user_id          String     @id @default(uuid())
  name             String
  username         String
  password         String
  role             users_role
  branch_id        String
  created_at       DateTime   @default(now()) @db.Timestamp(0)
  updated_at       DateTime   @default(now()) @updatedAt @db.DateTime(0)
  last_activity_at DateTime?  @db.DateTime(0)
  deleted_at       DateTime?  @db.DateTime(0)
  branch           branches   @relation(fields: [branch_id], references: [branch_id])
}

model expenses {
  expense_id    String           @id @default(uuid())
  amount        Decimal          @default(0) @db.Decimal(10, 2)
  purpose       expense_purpose
  remarks       String
  branch_id     String           @default("bd163cce-98e5-4513-b69e-875bd89c5f5c")
  employee_id   String?
  created_at    DateTime         @default(now()) @db.Timestamp(0)
  updated_at    DateTime         @default(now()) @updatedAt @db.DateTime(0)
  deleted_at    DateTime?        @db.DateTime(0)
  branch        branches         @relation(fields: [branch_id], references: [branch_id])
  employee      employees?       @relation(fields: [employee_id], references: [employee_id])
  payroll_entry payroll_entries?

  @@index([employee_id], map: "fk_expenses_employees")
}

model employees {
  employee_id    String          @id @default(uuid())
  first_name     String
  middle_name    String?
  last_name      String
  position       String?
  employee_type  employee_type   @default(REGULAR)
  status         employee_status @default(ACTIVE)
  contact_number String?
  remarks        String?         @db.Text
  branch_id      String

  // Personal & government info (from STAFF INFO sheet)
  birthday                 DateTime? @db.Date
  date_hired               DateTime? @db.Date
  address                  String?   @db.Text
  tin                      String?
  sss_number               String?
  philhealth_number        String?
  pagibig_number           String?
  emergency_contact_name   String?
  emergency_contact_number String?

  // Payroll configuration
  salary_type            salary_type        @default(DAILY_RATE)
  worker_type            worker_type        @default(REGULAR_WORKER)
  declaration_status     declaration_status @default(DECLARED)
  default_daily_rate     Decimal?           @db.Decimal(12, 2)
  default_monthly_salary Decimal?           @db.Decimal(12, 2)
  default_auction_rate   Decimal?           @db.Decimal(12, 2)
  default_container_rate Decimal?           @db.Decimal(12, 2)
  default_ot_hour_rate   Decimal?           @db.Decimal(10, 4)
  default_ot_minute_rate Decimal?           @db.Decimal(10, 4)

  created_at        DateTime                     @default(now()) @db.Timestamp(0)
  updated_at        DateTime                     @default(now()) @updatedAt @db.DateTime(0)
  deleted_at        DateTime?                    @db.DateTime(0)
  branch            branches                     @relation(fields: [branch_id], references: [branch_id])
  expenses          expenses[]
  payroll_entries   payroll_entries[]
  employment_events employee_employment_events[]

  @@index([branch_id], map: "fk_employees_branches")
  @@index([status])
  @@index([worker_type])
}

model employee_employment_events {
  event_id       String                @id @default(uuid())
  employee_id    String
  event_type     employment_event_type
  effective_date DateTime              @db.Date
  remarks        String?               @db.Text
  created_at     DateTime              @default(now()) @db.Timestamp(0)
  updated_at     DateTime              @default(now()) @updatedAt @db.DateTime(0)
  deleted_at     DateTime?             @db.DateTime(0)
  employee       employees             @relation(fields: [employee_id], references: [employee_id])

  @@index([employee_id, effective_date], map: "idx_employment_events_employee_date")
}

model payroll_periods {
  payroll_period_id String             @id @default(uuid())
  branch_id         String
  label             String
  period_start      DateTime           @db.Date
  period_end        DateTime           @db.Date
  pay_date          DateTime?          @db.Date
  status            payroll_run_status @default(DRAFT)
  posted_at         DateTime?          @db.DateTime(0)
  posted_by         String?
  remarks           String?            @db.Text
  created_at        DateTime           @default(now()) @db.Timestamp(0)
  updated_at        DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at        DateTime?          @db.DateTime(0)
  branch            branches           @relation(fields: [branch_id], references: [branch_id])
  entries           payroll_entries[]

  @@unique([branch_id, period_start, period_end], map: "uq_payroll_periods_branch_dates")
  @@index([branch_id, period_end], map: "idx_payroll_periods_branch_end")
  @@index([status])
}

model payroll_entries {
  payroll_entry_id  String @id @default(uuid())
  payroll_period_id String
  employee_id       String

  // Snapshot — frozen at the time of posting
  name_snapshot               String
  position_snapshot           String?
  salary_type_snapshot        salary_type
  worker_type_snapshot        worker_type
  declaration_status_snapshot declaration_status @default(DECLARED)
  daily_rate_snapshot         Decimal?           @db.Decimal(12, 2)
  monthly_salary_snapshot     Decimal?           @db.Decimal(12, 2)
  auction_rate_snapshot       Decimal?           @db.Decimal(12, 2)
  ot_hour_rate_snapshot       Decimal?           @db.Decimal(10, 4)
  ot_minute_rate_snapshot     Decimal?           @db.Decimal(10, 4)
  ot_rate_is_manual           Boolean            @default(false)
  sss_snapshot                String?
  philhealth_snapshot         String?
  pagibig_snapshot            String?
  tin_snapshot                String?

  // Inputs
  days_worked     Decimal @default(0) @db.Decimal(6, 2)
  days_leave_paid Decimal @default(0) @db.Decimal(6, 2)
  ot_hours        Decimal @default(0) @db.Decimal(6, 2)
  ot_minutes      Decimal @default(0) @db.Decimal(6, 2)
  worked_dates    Json?

  // Cached computed totals (recomputed on every save)
  basic_pay        Decimal @default(0) @db.Decimal(12, 2)
  gross_pay        Decimal @default(0) @db.Decimal(12, 2)
  total_deductions Decimal @default(0) @db.Decimal(12, 2)
  net_pay          Decimal @default(0) @db.Decimal(12, 2)

  // Payout link — set when period is marked paid
  expense_id String? @unique
  remarks    String? @db.Text

  created_at DateTime  @default(now()) @db.Timestamp(0)
  updated_at DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  period     payroll_periods      @relation(fields: [payroll_period_id], references: [payroll_period_id])
  employee   employees            @relation(fields: [employee_id], references: [employee_id])
  expense    expenses?            @relation(fields: [expense_id], references: [expense_id])
  earnings   payroll_earnings[]
  deductions payroll_deductions[]

  @@unique([payroll_period_id, employee_id], map: "uq_payroll_entries_period_employee")
  @@index([employee_id], map: "idx_payroll_entries_employee")
  @@index([payroll_period_id], map: "idx_payroll_entries_period")
  @@index([expense_id], map: "idx_payroll_entries_expense")
}

model payroll_earnings {
  payroll_earning_id String               @id @default(uuid())
  payroll_entry_id   String
  type               payroll_earning_type
  amount             Decimal              @default(0) @db.Decimal(12, 2)
  quantity           Decimal?             @db.Decimal(10, 4)
  rate               Decimal?             @db.Decimal(10, 4)
  remarks            String?
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @updatedAt @db.DateTime(0)
  entry              payroll_entries      @relation(fields: [payroll_entry_id], references: [payroll_entry_id], onDelete: Cascade)

  @@index([payroll_entry_id], map: "idx_payroll_earnings_entry")
}

model payroll_deductions {
  payroll_deduction_id String                 @id @default(uuid())
  payroll_entry_id     String
  type                 payroll_deduction_type
  amount               Decimal                @default(0) @db.Decimal(12, 2)
  remarks              String?
  created_at           DateTime               @default(now()) @db.Timestamp(0)
  updated_at           DateTime               @default(now()) @updatedAt @db.DateTime(0)
  entry                payroll_entries        @relation(fields: [payroll_entry_id], references: [payroll_entry_id], onDelete: Cascade)

  @@index([payroll_entry_id], map: "idx_payroll_deductions_entry")
}

model petty_cash {
  petty_cash_id String    @id @default(uuid())
  amount        Decimal   @default(0) @db.Decimal(10, 2)
  remarks       String
  branch_id     String
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at    DateTime? @db.DateTime(0)
  branch        branches  @relation(fields: [branch_id], references: [branch_id])
}

model counter_check {
  counter_check_id String    @id @default(uuid())
  auction_id       String
  control          String?
  bidder_number    String?
  price            String?
  description      String?
  time             String?
  page             String?
  error            String?
  remarks          String?
  created_at       DateTime  @default(now()) @db.Timestamp(0)
  updated_at       DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deleted_at       DateTime? @db.DateTime(0)
  auction          auctions  @relation(fields: [auction_id], references: [auction_id], map: "fk_counter_check_auctions")

  @@index([auction_id], map: "fk_counter_check_auctions")
}

model payment_methods {
  payment_method_id String     @id @default(uuid())
  name              String     @unique
  state             state      @default(DISABLED)
  created_at        DateTime   @default(now()) @db.Timestamp(0)
  updated_at        DateTime   @default(now()) @updatedAt @db.DateTime(0)
  deleted_at        DateTime?  @db.DateTime(0)
  payments          payments[]
}

